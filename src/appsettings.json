{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "00000000-0000-0000-0000-000000000000",
    "ClientId": "00000000-0000-0000-0000-000000000000",
    "Audience": "00000000-0000-0000-0000-000000000000"
  },
  "AzureOpenAI": {
    "Endpoint": "https://example-openai.openai.azure.com/",
    "Deployment": "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-large",
    "RewriteDeployment": "gpt-4o-mini"
  },
  "AzureSearch": {
    "Endpoint": "https://example-search.search.windows.net",
    "Index": "legal-index"
  },
  "IndexVersioning": {
    "StateFile": "data/index-version-state.json"
  },
  "Lineage": {
    "Path": "data/lineage-records.jsonl"
  },
  "Rag": {
    "MaxContextCharacters": 12000,
    "TopChunks": 5,
    "KNearestNeighbors": 5,
    "ConversationMemoryDepth": 5
  },
  "Costing": {
    "DefaultUsdPer1kTokens": 0.005
  },
  "Memory": {
    "Provider": "InMemory",
    "Redis": {
      "ConnectionString": "",
      "InstanceName": "legalrag",
      "KeyPrefix": "legalrag:conversation:",
      "TtlMinutes": 1440
    }
  },
  "Authorization": {
    "RequiredRole": "Api.Access",
    "RequiredScope": "access_as_user",
    "BypassAuthInDevelopment": false,
    "BypassMatterAuthorizationInDevelopment": true,
    "LogBypassWarnings": true,
    "EnableAzureAd": true,
    "EnableAclFilter": true,
    "MatterIdClaimTypes": [
      "matter_ids",
      "matters",
      "matterId",
      "extension_matterIds"
    ],
    "PermittedMattersClaimTypes": [
      "permittedMatters",
      "matter_ids",
      "matters",
      "matterId",
      "extension_matterIds"
    ],
    "GroupClaimTypes": [
      "groups",
      "group",
      "roles"
    ],
    "AllowedClientAppIds": []
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Features": {
    "EnableQueryRewrite": true
  },
  "DebugRag": {
    "Enabled": false
  }
}