# Copy this file to .env.shared and fill in your values.
# .env.shared is gitignored by the existing .env.* rule.

# Core
RAG_ENVIRONMENT="Development"
RAG_API_BASE_URL="http://localhost:5176"

# Entra / Auth
RAG_AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
RAG_AZURE_ENTRA_API_CLIENT_ID="00000000-0000-0000-0000-000000000000"
RAG_AZURE_ENTRA_FRONTEND_CLIENT_ID="00000000-0000-0000-0000-000000000000"
# Comma-separated client app IDs allowed to call the API. Leave empty to allow any app with required role/scope.
RAG_AZURE_ENTRA_ALLOWED_CLIENT_APP_IDS=""
RAG_AUTH_REQUIRED_SCOPE="access_as_user"
RAG_AUTH_REQUIRED_ROLE="Api.Access"
# Local debugging only. Ignored outside Development.
RAG_AUTH_BYPASS_IN_DEV="false"

# Azure OpenAI
RAG_AZURE_OPENAI_ENDPOINT="https://<your-openai-resource>.openai.azure.com/"
RAG_AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o"
RAG_AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-large"
# Optional when your search index vector field expects a specific dimension (for example 1536)
# RAG_AZURE_OPENAI_EMBEDDING_DIMENSIONS="1536"

# Azure AI Search
RAG_AZURE_SEARCH_ENDPOINT="https://<your-search-service>.search.windows.net"
RAG_AZURE_SEARCH_INDEX="legal-index"

# Optional: Key Vault name for application/runtime secret references
RAG_AZURE_KEYVAULT_NAME="<your-keyvault-name>"

# CORS
# Comma-separated origins for API CORS allowlist.
RAG_CORS_ALLOWED_ORIGINS="http://localhost:5173"
